#!/bin/bash
set -eu

backup_directory="/var/backups/minecraft"
timestamp="$(date +%Y-%m-%dT%H-%M-%S)"
archive="$backup_directory/hourly-$timestamp.tar"
server_was_running=false

log() {
    echo "$(date -Is) $(basename "$0"): $*"
}

send_command() {
    runuser -u minecraft -- \
        screen -p 0 -S minecraft -X eval "stuff \"$1\"\\015"
}

resume_saving() {
    if [ "$server_was_running" = true ]; then
        send_command "save-on" || true
    fi
}

exec >> /var/log/minecraft-maintenance.log 2>&1
trap resume_saving EXIT

if systemctl is-active --quiet minecraft; then
    server_was_running=true
    log "flushing world data"
    send_command "save-off"
    send_command "save-all flush"
    sleep 5
fi

log "creating $archive"
tar -cpf "$archive" -C / srv/minecraft

log "removing hourly snapshots older than one day"
find "$backup_directory" -maxdepth 1 \
    -type f -name 'hourly-*.tar' -mmin +1440 -delete

log "snapshot complete"
