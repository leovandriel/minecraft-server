#!/bin/bash
set -e
exec &>> /opt/minecraft/logs/update-server.log
echo "$(date -Is): stop"
systemctl stop minecraft
echo "$(date -Is): backup"
sudo /usr/local/bin/backup-daily
echo "$(date -Is): download"
sudo -u minecraft /usr/local/bin/download-paper
echo "$(date -Is): start"
systemctl start minecraft
echo "$(date -Is): update complete"
